# 复制为 .env 后按需填写。勿将含密钥的 .env 提交到版本库。

NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=topchef

# JWT（生产环境务必使用足够长的随机串）
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# 微信小程序登录（jscode2session）；未配置时登录接口会失败
WECHAT_APPID=
WECHAT_APPSECRET=

# CORS：逗号分隔的完整 Origin（含协议与端口），例如：
#   https://your-h5.example.com,http://localhost:10086
# 开发环境若不配置，将使用内置的 localhost 默认列表。
# 无 Origin 的请求（如微信小程序 wx.request、curl）不受白名单影响。
CORS_ORIGINS=

# 置于反向代理后时需信任代理，否则限流按到的可能是代理 IP
# TRUST_PROXY=1

# 限流（可选；单位为毫秒 / 次）
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_LOGIN_MAX=30
# RATE_LIMIT_WRITE_WINDOW_MS=900000
# RATE_LIMIT_WRITE_MAX=300
