# 应用配置示例
# 复制此文件为 .env.local 并填入实际的值

# 小程序 AppID（可选，开发时可留空）
VITE_APP_ID=your_app_id_here

# 环境变量
NODE_ENV=development

# 应用名称
VITE_APP_NAME=TopChef

# 应用版本
VITE_APP_VERSION=1.0.0

# 应用描述
VITE_APP_DESC=一个用于记录和管理菜肴的微信小程序

# API 基础 URL（如需要后端服务）
VITE_API_BASE_URL=https://api.example.com

# 调试模式
VITE_DEBUG=false
